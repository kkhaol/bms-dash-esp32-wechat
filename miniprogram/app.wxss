page {
  min-height: 100%;
  color: #edf4ff;
  background: #08111f;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

view,
text,
button,
switch {
  box-sizing: border-box;
}

button {
  margin: 0;
  border-radius: 10rpx;
  font-weight: 700;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at 20% 0%, rgba(36, 214, 162, 0.16), transparent 34%),
    linear-gradient(180deg, #0a1628 0%, #08111f 42%, #050914 100%);
}

.section {
  margin-top: 24rpx;
}

.section-title {
  margin-bottom: 16rpx;
  color: #90a4bf;
  font-size: 24rpx;
  letter-spacing: 1rpx;
}

.panel {
  padding: 24rpx;
  border: 1rpx solid rgba(144, 164, 191, 0.16);
  border-radius: 14rpx;
  background: rgba(10, 22, 40, 0.88);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.muted {
  color: #7f8da3;
}

.strong {
  color: #edf4ff;
  font-weight: 700;
}

.ok {
  color: #24d6a2;
}

.warn {
  color: #ffbf47;
}

.danger {
  color: #ff6b6b;
}

.btn-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.action-wrap {
  position: relative;
}

.btn {
  min-height: 86rpx;
  width: 100%;
  color: #06141f;
  background: #24d6a2;
  font-size: 28rpx;
}

.btn.secondary {
  color: #eaf2ff;
  background: #1b2a40;
}

.btn.warn {
  color: #08111f;
  background: #ffbf47;
}

.btn.danger {
  color: #ffffff;
  background: #d84d4d;
}

.btn[disabled] {
  color: #6d7b90;
  background: #152033;
}

.help-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border: 2rpx solid rgba(237, 244, 255, 0.86);
  border-radius: 50%;
  color: #08111f;
  background: #edf4ff;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 38rpx;
}

.tip-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(0, 0, 0, 0.62);
}

.tip-card {
  width: 100%;
  max-width: 620rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(36, 214, 162, 0.35);
  border-radius: 16rpx;
  background: #0a1628;
}

.tip-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
}

.tip-text {
  margin-top: 16rpx;
  color: #b9c7da;
  font-size: 26rpx;
  line-height: 1.55;
}

.tip-close {
  margin-top: 22rpx;
  color: #24d6a2;
  font-size: 24rpx;
}

.empty {
  padding: 36rpx 22rpx;
  border: 1rpx dashed rgba(144, 164, 191, 0.24);
  border-radius: 12rpx;
  color: #7f8da3;
  text-align: center;
}

.log-box {
  max-height: 360rpx;
  overflow: auto;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #050914;
}

.log-line {
  margin-bottom: 10rpx;
  color: #9eb0c9;
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-all;
}
