page {
  min-height: 100%;
  color: #edf4ff;
  background: #08111f;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

view,
text,
button,
switch,
slider {
  box-sizing: border-box;
}

button {
  margin: 0;
  border-radius: 32rpx;
  font-weight: 800;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 150rpx;
  background:
    radial-gradient(circle at 50% -12%, rgba(37, 240, 176, 0.13), transparent 36%),
    linear-gradient(180deg, #0a1628 0%, #08111f 45%, #050914 100%);
}

.section {
  margin-top: 28rpx;
}

.section-title {
  margin-bottom: 16rpx;
  color: #7f8da3;
  font-size: 24rpx;
  font-weight: 700;
}

.ok {
  color: #25f0b0;
  font-weight: 800;
}

.warn {
  color: #ffbf47;
  font-weight: 800;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 104rpx;
  border-radius: 32rpx;
  color: #06141f;
  background: #25f0b0;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 104rpx;
}

.btn.primary {
  color: #06141f;
  background: #25f0b0;
}

.btn.secondary {
  color: #edf4ff;
  background: rgba(255, 255, 255, 0.09);
}

.btn.danger {
  color: #ffffff;
  background: #d84d4d;
}

.btn[disabled] {
  color: #66758b;
  background: rgba(255, 255, 255, 0.08);
}

.empty {
  padding: 34rpx 24rpx;
  border-radius: 22rpx;
  color: #7f8da3;
  background: rgba(255, 255, 255, 0.045);
  font-size: 26rpx;
  line-height: 1.45;
  text-align: center;
}

.log-box {
  max-height: 420rpx;
  overflow: auto;
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(0, 0, 0, 0.24);
}

.log-line {
  margin-bottom: 12rpx;
  color: #9eb0c9;
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-all;
}
