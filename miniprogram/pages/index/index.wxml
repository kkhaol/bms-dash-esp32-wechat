<view class="page dashboard-page">
  <view class="hero">
    <view>
      <view class="eyebrow">X仪表</view>
      <view class="title">电池状态</view>
    </view>
    <view class="status-pill {{view.dashboardConnected ? 'online' : ''}}">
      {{view.dashboardConnected ? '在线' : '离线'}}
    </view>
  </view>

  <view class="status-card">
    <view class="status-row">
      <text class="status-label">X仪表</text>
      <text class="{{view.dashboardConnected ? 'ok' : 'warn'}}">{{view.dashboardConnected ? '已连接' : '未连接'}}</text>
    </view>
    <view class="status-row">
      <text class="status-label">电池</text>
      <text class="{{view.bmsConnected ? 'ok' : 'warn'}}">{{view.bmsConnected ? '已连接' : '未连接'}}</text>
    </view>
    <view class="status-row">
      <text class="status-label">当前电池</text>
      <text class="bms-name">{{view.bmsName}}</text>
    </view>
  </view>

  <view wx:if="{{view.dashboardConnected && view.bmsConnected}}" class="battery-panel">
    <view class="soc-ring" style="background: conic-gradient(#25f0b0 0deg, #25f0b0 {{view.socDegree}}deg, rgba(255,255,255,0.08) {{view.socDegree}}deg, rgba(255,255,255,0.08) 360deg);">
      <view class="soc-core">
        <view class="soc-value-wrap">
          <text class="soc-number">{{view.socText}}</text>
          <text class="soc-percent">%</text>
        </view>
        <text class="soc-label">电量</text>
      </view>
    </view>

    <view class="metric-row">
      <view class="metric">
        <text class="metric-label">电压</text>
        <text class="metric-value">{{view.voltageText}}</text>
      </view>
      <view class="metric">
        <text class="metric-label">温度</text>
        <text class="metric-value">{{view.temperatureText}}</text>
      </view>
    </view>
  </view>

  <view wx:else class="connect-panel">
    <view class="connect-title">{{view.dashboardConnected ? '请选择你的电池' : '连接后查看电池状态'}}</view>
    <button class="btn primary main-action" loading="{{busy}}" disabled="{{busy}}" bindtap="handlePrimaryAction">
      {{view.primaryText}}
    </button>
  </view>
</view>
