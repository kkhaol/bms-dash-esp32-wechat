.dashboard-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-top: 10rpx;
}

.eyebrow {
  color: #25f0b0;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.title {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 850;
  line-height: 1.1;
}

.status-pill {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  color: #ffbf47;
  background: rgba(255, 191, 71, 0.12);
  font-size: 24rpx;
  font-weight: 800;
}

.status-pill.online {
  color: #25f0b0;
  background: rgba(37, 240, 176, 0.14);
}

.status-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: rgba(10, 22, 40, 0.72);
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 44rpx;
  font-size: 28rpx;
}

.status-label {
  color: #7f8da3;
}

.bms-name {
  max-width: 420rpx;
  overflow: hidden;
  color: #edf4ff;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.battery-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 42rpx;
  padding-top: 16rpx;
}

.soc-ring {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 430rpx;
  height: 430rpx;
  border-radius: 50%;
  box-shadow:
    0 0 80rpx rgba(37, 240, 176, 0.18),
    inset 0 0 42rpx rgba(255, 255, 255, 0.06);
}

.soc-core {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 24%, #152a3f 0%, #08111f 66%);
}

.soc-value-wrap {
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.soc-number {
  color: #ffffff;
  font-size: 116rpx;
  font-weight: 900;
  line-height: 1;
}

.soc-percent {
  margin-top: 14rpx;
  margin-left: 4rpx;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
}

.soc-label {
  margin-top: 12rpx;
  color: #7f8da3;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.metric-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  width: 100%;
}

.metric {
  min-height: 142rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.055);
}

.metric-label {
  display: block;
  color: #7f8da3;
  font-size: 24rpx;
}

.metric-value {
  display: block;
  margin-top: 22rpx;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 850;
}

.connect-panel {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  min-height: 520rpx;
  gap: 28rpx;
}

.connect-title {
  color: #edf4ff;
  font-size: 44rpx;
  font-weight: 850;
  line-height: 1.2;
}

.main-action {
  margin-top: 6rpx;
}
