.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding-top: 10rpx;
}

.eyebrow {
  color: #24d6a2;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.title {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.18;
}

.status-pill {
  flex: 0 0 auto;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #ffbf47;
  background: rgba(255, 191, 71, 0.12);
  font-size: 24rpx;
  font-weight: 700;
}

.status-pill.online {
  color: #24d6a2;
  background: rgba(36, 214, 162, 0.14);
}

.status-panel {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 52rpx;
  font-size: 28rpx;
}

.bms-current {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  min-width: 0;
}

.mac,
.device-id {
  max-width: 420rpx;
  overflow: hidden;
  font-family: "SF Mono", Consolas, monospace;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.data-panel {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 16rpx;
}

.soc-card {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 266rpx;
  border: 1rpx solid rgba(36, 214, 162, 0.18);
  border-radius: 14rpx;
  background: rgba(10, 22, 40, 0.88);
}

.soc-pie {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 214rpx;
  height: 214rpx;
  border-radius: 50%;
  box-shadow: 0 0 40rpx rgba(36, 214, 162, 0.18);
}

.soc-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 146rpx;
  height: 146rpx;
  border-radius: 50%;
  background: #08111f;
}

.soc-value {
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
}

.soc-unit {
  margin-top: 4rpx;
  color: #90a4bf;
  font-size: 22rpx;
}

.metric-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.metric {
  min-height: 142rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(36, 214, 162, 0.18);
  border-radius: 14rpx;
  background: linear-gradient(180deg, rgba(36, 214, 162, 0.12), rgba(10, 22, 40, 0.92));
}

.metric.slim {
  min-height: 125rpx;
}

.metric-label {
  display: block;
  color: #90a4bf;
  font-size: 22rpx;
}

.metric-value {
  display: block;
  margin-top: 20rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
}

.device-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(144, 164, 191, 0.14);
  border-radius: 12rpx;
  background: rgba(10, 22, 40, 0.72);
}

.device-item.selected {
  border-color: rgba(36, 214, 162, 0.62);
  background: rgba(36, 214, 162, 0.12);
}

.rssi {
  flex: 0 0 auto;
  color: #24d6a2;
  font-family: "SF Mono", Consolas, monospace;
  font-size: 24rpx;
  font-weight: 700;
}
