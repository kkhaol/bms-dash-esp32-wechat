<view class="page">
  <view class="topbar">
    <view>
      <view class="eyebrow">DASH SETTINGS</view>
      <view class="title">仪表设置</view>
    </view>
    <view class="status-pill {{state.dashboardConnected ? 'online' : ''}}">
      {{state.dashboardConnected ? '在线' : '离线'}}
    </view>
  </view>

  <view class="section">
    <view class="section-title">仪表维护</view>
    <view class="btn-grid">
      <view class="action-wrap">
        <button class="btn secondary" disabled="{{busy || !state.dashboardConnected}}" bindtap="pingEsp32">PING</button>
        <view class="help-btn" catchtap="showTip" data-title="PING" data-text="向 ESP32 发送 PING。收到 {type:pong} 代表手机与 ESP32 的配置通道可用。">?</view>
      </view>
      <view class="action-wrap">
        <button class="btn warn" disabled="{{busy || !state.dashboardConnected}}" bindtap="rebootEsp32">重启 ESP32</button>
        <view class="help-btn" catchtap="showTip" data-title="重启 ESP32" data-text="向 ESP32 发送 REBOOT。重启后小程序需要重新搜索并连接仪表。">?</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="panel info-card">
      <view class="row">
        <text class="muted">Service</text>
        <text class="mono">6E400001</text>
      </view>
      <view class="row">
        <text class="muted">RX 写入</text>
        <text class="mono">6E400002</text>
      </view>
      <view class="row">
        <text class="muted">TX 通知</text>
        <text class="mono">6E400003</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">调试日志</view>
    <view class="log-box">
      <view wx:if="{{logs.length === 0}}" class="log-line">暂无日志</view>
      <view wx:for="{{logs}}" wx:key="*this" class="log-line">{{item}}</view>
    </view>
  </view>

  <view wx:if="{{tipVisible}}" class="tip-mask" bindtap="hideTip">
    <view class="tip-card">
      <view class="tip-title">{{tipTitle}}</view>
      <view class="tip-text">{{tipText}}</view>
      <view class="tip-close">点击任意位置关闭</view>
    </view>
  </view>
</view>
