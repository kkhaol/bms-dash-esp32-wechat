<view class="page settings-page">
  <view class="topbar">
    <view>
      <view class="eyebrow">X仪表</view>
      <view class="title">设置</view>
    </view>
    <view class="status-pill {{state.dashboardConnected ? 'online' : ''}}">
      {{state.dashboardConnected ? '在线' : '离线'}}
    </view>
  </view>

  <view class="settings-card">
    <view class="setting-row">
      <view>
        <view class="setting-title">自动连接上次电池</view>
        <view class="setting-note">有保存记录时，优先回到上次使用的电池。</view>
      </view>
      <switch checked="{{settings.autoLastBms}}" data-key="autoLastBms" bindchange="onSwitchChange" color="#25f0b0" />
    </view>

    <view class="setting-row">
      <view>
        <view class="setting-title">优先选择信号更强的电池</view>
        <view class="setting-note">搜索结果会优先选中信号更强的电池。</view>
      </view>
      <switch checked="{{settings.preferStrongest}}" data-key="preferStrongest" bindchange="onSwitchChange" color="#25f0b0" />
    </view>

    <view class="setting-block">
      <view class="setting-head">
        <text class="setting-title">屏幕亮度</text>
        <text class="setting-value">{{settings.brightness}}%</text>
      </view>
      <slider value="{{settings.brightness}}" min="20" max="100" step="5" activeColor="#25f0b0" backgroundColor="#243246" block-color="#ffffff" block-size="22" bindchange="onBrightnessChange" />
    </view>

    <view class="setting-block">
      <view class="setting-head">
        <text class="setting-title">低电量提醒阈值</text>
        <text class="setting-value">{{settings.lowBatteryThreshold}}%</text>
      </view>
      <slider value="{{settings.lowBatteryThreshold}}" min="5" max="40" step="1" activeColor="#25f0b0" backgroundColor="#243246" block-color="#ffffff" block-size="22" bindchange="onLowBatteryChange" />
    </view>
  </view>

  <button class="btn danger restore-btn" bindtap="restoreDefaults">恢复默认设置</button>
</view>
