.bms-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.topbar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-top: 10rpx;
}

.eyebrow {
  color: #25f0b0;
  font-size: 24rpx;
  font-weight: 800;
}

.title {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 850;
  line-height: 1.1;
}

.status-dot {
  width: 22rpx;
  height: 22rpx;
  margin-top: 18rpx;
  border-radius: 50%;
  background: #ffbf47;
  box-shadow: 0 0 26rpx rgba(255, 191, 71, 0.42);
}

.status-dot.online {
  background: #25f0b0;
  box-shadow: 0 0 28rpx rgba(37, 240, 176, 0.5);
}

.connect-card,
.selected-panel {
  padding: 30rpx;
  border-radius: 24rpx;
  background: rgba(10, 22, 40, 0.76);
}

.connect-card {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.connect-title {
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 850;
}

.connect-text {
  color: #7f8da3;
  font-size: 26rpx;
  line-height: 1.5;
}

.selected-panel {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.selected-label {
  color: #7f8da3;
  font-size: 24rpx;
}

.selected-name {
  margin-top: 10rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 850;
}

.selected-mac,
.mac {
  margin-top: 8rpx;
  color: #66758b;
  font-family: "SF Mono", Consolas, monospace;
  font-size: 22rpx;
  word-break: break-all;
}

.selected-state {
  flex: 0 0 auto;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #ffbf47;
  background: rgba(255, 191, 71, 0.12);
  font-size: 22rpx;
  font-weight: 800;
}

.selected-state.online {
  color: #25f0b0;
  background: rgba(37, 240, 176, 0.14);
}

.main-btn {
  margin-top: 18rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.text-btn {
  flex: 0 0 auto;
  margin: 0;
  padding: 0 8rpx;
  color: #7f8da3;
  background: transparent;
  font-size: 24rpx;
  line-height: 1.6;
}

.text-btn::after,
.delete-btn::after {
  border: 0;
}

.bms-card {
  margin-bottom: 18rpx;
  padding: 28rpx;
  border: 2rpx solid transparent;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.055);
}

.bms-card.selected {
  border-color: rgba(37, 240, 176, 0.8);
  background: rgba(37, 240, 176, 0.12);
  box-shadow: 0 0 38rpx rgba(37, 240, 176, 0.12);
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.card-actions {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  gap: 12rpx;
}

.bms-name {
  min-width: 0;
  overflow: hidden;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 850;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #25f0b0;
  background: rgba(37, 240, 176, 0.14);
  font-size: 22rpx;
  font-weight: 800;
}

.delete-btn {
  flex: 0 0 auto;
  margin: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #9aa8bb;
  background: rgba(255, 255, 255, 0.06);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.25;
}

.signal {
  margin-top: 18rpx;
  color: #dce7f7;
  font-size: 26rpx;
  font-weight: 700;
}
