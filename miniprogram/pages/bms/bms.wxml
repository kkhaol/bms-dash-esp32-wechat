<view class="page bms-page">
  <view class="topbar">
    <view>
      <view class="eyebrow">电池</view>
      <view class="title">选择你的电池</view>
    </view>
    <view class="status-dot {{state.bmsConnected ? 'online' : ''}}"></view>
  </view>

  <view wx:if="{{!state.dashboardConnected}}" class="connect-card">
    <view class="connect-title">先连接X仪表</view>
    <view class="connect-text">连接后即可扫描并选择你的电池。</view>
    <button class="btn primary" loading="{{busy}}" disabled="{{busy}}" bindtap="connectInstrument">连接X仪表</button>
  </view>

  <view wx:else>
    <view class="selected-panel">
      <view>
        <view class="selected-label">当前选择</view>
        <view class="selected-name">{{selectedName || '未选择电池'}}</view>
      </view>
      <view class="selected-state {{state.bmsConnected ? 'online' : ''}}">
        {{state.bmsConnected ? '已连接' : '未连接'}}
      </view>
    </view>

    <button class="btn primary main-btn" loading="{{busy}}" disabled="{{busy || !selectedMac}}" bindtap="connectSelectedBms">连接此电池</button>
    <button class="btn secondary main-btn" loading="{{state.bmsScanning}}" disabled="{{busy || state.bmsScanning}}" bindtap="scanBms">搜索附近电池</button>

    <view class="section">
      <view class="section-title">历史电池</view>
      <view wx:if="{{bmsHistory.length === 0}}" class="empty">连接成功后，常用电池会显示在这里。</view>
      <view wx:for="{{bmsHistory}}" wx:key="mac" class="bms-card {{item.selected ? 'selected' : ''}}" bindtap="chooseBms" data-mac="{{item.mac}}">
        <view class="card-head">
          <view class="bms-name">{{item.displayName}}</view>
          <view wx:if="{{item.isLast}}" class="tag">上次使用</view>
        </view>
        <view class="signal">信号 {{item.signalText}}</view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">附近电池</view>
      <view wx:if="{{bmsList.length === 0}}" class="empty">点击“搜索附近电池”查找可连接的电池。</view>
      <view wx:for="{{bmsList}}" wx:key="mac" class="bms-card {{item.selected ? 'selected' : ''}}" bindtap="chooseBms" data-mac="{{item.mac}}">
        <view class="card-head">
          <view class="bms-name">{{item.displayName}}</view>
          <view wx:if="{{item.isLast}}" class="tag">上次使用</view>
        </view>
        <view class="signal">信号 {{item.signalText}}</view>
      </view>
    </view>
  </view>
</view>
